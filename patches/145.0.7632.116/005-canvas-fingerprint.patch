+// Aspect: content-dependent canvas noise adapted from upstream noise_helper.cc
+struct AspectNoiseHash {
+  uint64_t state;
+  void Feed(uint64_t v) {
+    state ^= v;
+    state *= 0x100000001b3ULL;  // FNV1a prime
+  }
+  int GetValueBelow(int max_exclusive) {
+    if (max_exclusive <= 1) return 0;
+    Feed(0);
+    return static_cast<int>(state % static_cast<uint64_t>(max_exclusive));
+  }
+};
+
+void AspectNoisePixels(uint64_t seed, uint8_t* pixels, int width, int height) {
+  if (seed == 0 || width <= 0 || height <= 0) return;
+  constexpr int kMaxNoise = 3;
+  constexpr int kChannels = 4;
+
+  std::vector<uint8_t> prev_orig(width * kChannels, 0);
+  std::vector<uint8_t> curr_orig(width * kChannels);
+
+  for (int y = 0; y < height; ++y) {
+    uint8_t* row = pixels + y * width * kChannels;
+    std::memcpy(curr_orig.data(), row, width * kChannels);
+
+    for (int x = 0; x < width; ++x) {
+      uint8_t* px = row + x * kChannels;
+      if (px[0] == 0 && px[1] == 0 && px[2] == 0 && px[3] == 0) continue;
+
+      const uint8_t* orig = curr_orig.data() + x * kChannels;
+
+      auto matches = [](const uint8_t* a, const uint8_t* b) {
+        return a[0]==b[0] && a[1]==b[1] && a[2]==b[2] && a[3]==b[3];
+      };
+      if (y > 0 && x > 0 && matches(prev_orig.data()+(x-1)*kChannels, orig)) {
+        std::memcpy(px, pixels+((y-1)*width+(x-1))*kChannels, kChannels); continue;
+      }
+      if (y > 0 && matches(prev_orig.data()+x*kChannels, orig)) {
+        std::memcpy(px, pixels+((y-1)*width+x)*kChannels, kChannels); continue;
+      }
+      if (y > 0 && x < width-1 && matches(prev_orig.data()+(x+1)*kChannels, orig)) {
+        std::memcpy(px, pixels+((y-1)*width+(x+1))*kChannels, kChannels); continue;
+      }
+      if (x > 0 && matches(curr_orig.data()+(x-1)*kChannels, orig)) {
+        std::memcpy(px, row+(x-1)*kChannels, kChannels); continue;
+      }
+
+      AspectNoiseHash h{seed ^ 0xcbf29ce484222325ULL};
+      h.Feed(static_cast<uint64_t>(x) | (static_cast<uint64_t>(y) << 20));
+      h.Feed(*reinterpret_cast<const uint32_t*>(orig));
+
+      for (int ch = 0; ch < kChannels; ++ch) {
+        int v = px[ch];
+        int lo = (ch == 3 && v > 0) ? 1 : 0;
+        int mn = std::max(lo, v - kMaxNoise);
+        int mx = std::min(255, v + kMaxNoise);
+        int range = std::min(kMaxNoise * 2 + 1, mx - mn + 1);
+        px[ch] = static_cast<uint8_t>(mn + h.GetValueBelow(range));
+      }
+    }
+    std::swap(prev_orig, curr_orig);
+  }
+}
+
 }  // namespace
 
 constexpr char kDefaultFont[] = "10px sans-serif";
@@ -524,6 +601,22 @@ ImageData* BaseRenderingContext2D::getImageDataInternal(
           snapshot->PaintImageForCurrentFrame().GetSkImageInfo().bounds();
       DCHECK(!bounds.intersect(SkIRect::MakeXYWH(sx, sy, sw, sh)));
     }
+
+    static const uint64_t canvas_seed = []() -> uint64_t {
+      uint64_t s = 0;
+      const auto& cmd = *base::CommandLine::ForCurrentProcess();
+      if (cmd.HasSwitch(blink::switches::kAspectCanvasNoiseSeed))
+        base::StringToUint64(
+            cmd.GetSwitchValueASCII(blink::switches::kAspectCanvasNoiseSeed),
+            &s);
+      return s;
+    }();
+    if (canvas_seed != 0 && read_pixels_successful) {
+      AspectNoisePixels(
+          canvas_seed,
+          static_cast<uint8_t*>(image_data_pixmap.writable_addr()),
+          image_data_pixmap.width(), image_data_pixmap.height());
+    }
   }
 
   return image_data;
