index c1a2cdda7cd24..0892307e37b51 100644
--- a/third_party/blink/renderer/platform/graphics/canvas_resource_provider.cc
+++ b/third_party/blink/renderer/platform/graphics/canvas_resource_provider.cc
@@ -65,9 +65,72 @@
 #include "third_party/skia/include/gpu/ganesh/SkSurfaceGanesh.h"
 #include "third_party/skia/include/gpu/ganesh/gl/GrGLBackendSurface.h"
 #include "third_party/skia/include/gpu/ganesh/gl/GrGLTypes.h"
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "third_party/blink/public/common/switches.h"
+#include "third_party/skia/include/core/SkPixmap.h"
 
 namespace blink {
 
+namespace {
+// Aspect: idempotent canvas noise — f(f(x)) = f(x).
+// Quantizes each channel to a grid of 4 then adds a position-dependent offset.
+uint64_t GetAspectCanvasNoiseSeed() {
+  static const uint64_t seed = []() -> uint64_t {
+    uint64_t v = 0;
+    const auto& cmd = *base::CommandLine::ForCurrentProcess();
+    if (cmd.HasSwitch(blink::switches::kAspectCanvasNoiseSeed)) {
+      base::StringToUint64(
+          cmd.GetSwitchValueASCII(blink::switches::kAspectCanvasNoiseSeed), &v);
+    }
+    return v;
+  }();
+  return seed;
+}
+
+void ApplyAspectCanvasNoise(SkSurface* surface, uint64_t seed) {
+  if (!surface || seed == 0)
+    return;
+  SkPixmap pixmap;
+  if (!surface->peekPixels(&pixmap))
+    return;
+  const int width = pixmap.width();
+  const int height = pixmap.height();
+  if (pixmap.colorType() != kRGBA_8888_SkColorType &&
+      pixmap.colorType() != kBGRA_8888_SkColorType &&
+      pixmap.colorType() != kN32_SkColorType) {
+    return;
+  }
+  constexpr uint64_t kFnvPrime = 0x00000100000001b3ULL;
+  for (int y = 0; y < height; ++y) {
+    for (int x = 0; x < width; ++x) {
+      uint32_t* addr = pixmap.writable_addr32(x, y);
+      uint32_t px = *addr;
+      // Skip fully transparent pixels.
+      if ((px >> 24) == 0)
+        continue;
+      uint32_t result = px & 0xFF000000u;  // Preserve alpha.
+      for (int c = 0; c < 3; ++c) {
+        uint64_t h = seed;
+        h ^= static_cast<uint64_t>(x);
+        h *= kFnvPrime;
+        h ^= static_cast<uint64_t>(y);
+        h *= kFnvPrime;
+        h ^= static_cast<uint64_t>(c);
+        h *= kFnvPrime;
+        int offset = static_cast<int>(h % 4);
+        int v = static_cast<int>((px >> (c * 8)) & 0xFF);
+        int quantized = (v / 4) * 4 + offset;
+        result |= static_cast<uint32_t>(std::clamp(quantized, 0, 255))
+                  << (c * 8);
+      }
+      *addr = result;
+    }
+  }
+  surface->notifyContentWillChange(SkSurface::kRetain_ContentChangeMode);
+}
+}  // namespace
+
 BASE_FEATURE(kSkipRedundantWillDraw, base::FEATURE_ENABLED_BY_DEFAULT);
 
 class FlushForImageListener {
@@ -1641,6 +1704,11 @@ std::optional<cc::PaintRecord> CanvasResourceProvider::FlushCanvas(
   cc::PaintRecord recording;
   recording = recorder_->ReleaseMainRecording();
   RasterRecord(recording);
+  // Aspect: apply idempotent canvas noise after rasterization.
+  uint64_t noise_seed = GetAspectCanvasNoiseSeed();
+  if (noise_seed != 0 && !IsAccelerated()) {
+    ApplyAspectCanvasNoise(GetSkSurface(), noise_seed);
+  }
   // Images are locked for the duration of the rasterization, in case they get
   // used multiple times. We can unlock them once the rasterization is complete.
   ReleaseLockedImages();
