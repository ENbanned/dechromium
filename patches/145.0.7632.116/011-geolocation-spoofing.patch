From f6af20d3e131d76b6c4fb4b8563407e07070754b Mon Sep 17 00:00:00 2001
From: ENbanned <nik.skvortsov2007@gmail.com>
Date: Sun, 1 Mar 2026 13:52:58 +0000
Subject: [PATCH 11/15] 011-geolocation-spoofing

---
 .../renderer_host/render_process_host_impl.cc |  2 ++
 third_party/blink/common/switches.cc          |  2 ++
 third_party/blink/public/common/switches.h    |  3 ++
 .../renderer/core/geolocation/geolocation.cc  | 29 +++++++++++++++++--
 4 files changed, 34 insertions(+), 2 deletions(-)

diff --git a/content/browser/renderer_host/render_process_host_impl.cc b/content/browser/renderer_host/render_process_host_impl.cc
index 891f6f8672203..a677c006a061b 100644
--- a/content/browser/renderer_host/render_process_host_impl.cc
+++ b/content/browser/renderer_host/render_process_host_impl.cc
@@ -3818,6 +3818,8 @@ void RenderProcessHostImpl::PropagateBrowserCommandLineToRenderer(
       blink::switches::kAspectFontFamilies,
       blink::switches::kAspectWebglVersion,
       blink::switches::kAspectWebglGlslVersion,
+      blink::switches::kAspectGeoLatitude,
+      blink::switches::kAspectGeoLongitude,
       blink::switches::kAspectTimezone,
       blink::switches::kAspectScreenAvailTop,
       blink::switches::kAspectScrollbarStyle,
diff --git a/third_party/blink/common/switches.cc b/third_party/blink/common/switches.cc
index e46aabb7433e8..3c38f8dc89b46 100644
--- a/third_party/blink/common/switches.cc
+++ b/third_party/blink/common/switches.cc
@@ -187,6 +187,8 @@ const char kAspectDomrectNoiseSeed[] = "aspect-domrect-noise-seed";
 const char kAspectFontFamilies[] = "aspect-font-families";
 const char kAspectWebglVersion[] = "aspect-webgl-version";
 const char kAspectWebglGlslVersion[] = "aspect-webgl-glsl-version";
+const char kAspectGeoLatitude[] = "aspect-geo-latitude";
+const char kAspectGeoLongitude[] = "aspect-geo-longitude";
 const char kAspectTimezone[] = "aspect-timezone";
 const char kAspectScreenAvailTop[] = "aspect-screen-avail-top";
 const char kAspectScrollbarStyle[] = "aspect-scrollbar-style";
diff --git a/third_party/blink/public/common/switches.h b/third_party/blink/public/common/switches.h
index 218e787b705a9..f390f0d4c3eee 100644
--- a/third_party/blink/public/common/switches.h
+++ b/third_party/blink/public/common/switches.h
@@ -89,6 +89,9 @@ BLINK_COMMON_EXPORT extern const char kAspectFontFamilies[];
 // WebGL version strings:
 BLINK_COMMON_EXPORT extern const char kAspectWebglVersion[];
 BLINK_COMMON_EXPORT extern const char kAspectWebglGlslVersion[];
+// Geolocation:
+BLINK_COMMON_EXPORT extern const char kAspectGeoLatitude[];
+BLINK_COMMON_EXPORT extern const char kAspectGeoLongitude[];
 // Timezone:
 BLINK_COMMON_EXPORT extern const char kAspectTimezone[];
 // Screen availTop (macOS menu bar offset):
diff --git a/third_party/blink/renderer/core/geolocation/geolocation.cc b/third_party/blink/renderer/core/geolocation/geolocation.cc
index 640ee17dcfecd..4e968c79c3f18 100644
--- a/third_party/blink/renderer/core/geolocation/geolocation.cc
+++ b/third_party/blink/renderer/core/geolocation/geolocation.cc
@@ -51,6 +51,9 @@
 #include "third_party/blink/renderer/core/timing/epoch_time_stamp.h"
 #include "third_party/blink/renderer/platform/bindings/source_location.h"
 #include "third_party/blink/renderer/platform/runtime_enabled_features.h"
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "third_party/blink/public/common/switches.h"
 
 namespace blink {
 namespace {
@@ -65,12 +68,34 @@ const char kFeaturePolicyConsoleWarning[] =
 
 Geoposition* CreateGeoposition(
     const device::mojom::blink::Geoposition& position) {
+  double latitude = position.latitude;
+  double longitude = position.longitude;
+  double accuracy = position.accuracy;
+
+  const auto& cmd = *base::CommandLine::ForCurrentProcess();
+  if (cmd.HasSwitch(blink::switches::kAspectGeoLatitude) &&
+      cmd.HasSwitch(blink::switches::kAspectGeoLongitude)) {
+    double lat_val, lng_val;
+    if (base::StringToDouble(
+            cmd.GetSwitchValueASCII(blink::switches::kAspectGeoLatitude),
+            &lat_val) &&
+        base::StringToDouble(
+            cmd.GetSwitchValueASCII(blink::switches::kAspectGeoLongitude),
+            &lng_val) &&
+        lat_val >= -90.0 && lat_val <= 90.0 &&
+        lng_val >= -180.0 && lng_val <= 180.0) {
+      latitude = lat_val;
+      longitude = lng_val;
+      accuracy = 100.0;
+    }
+  }
+
   auto* coordinates = MakeGarbageCollected<GeolocationCoordinates>(
-      position.latitude, position.longitude,
+      latitude, longitude,
       // Lowest point on land is at approximately -400 meters.
       position.altitude > -10000. ? std::make_optional(position.altitude)
                                   : std::nullopt,
-      position.accuracy,
+      accuracy,
       position.altitude_accuracy >= 0.
           ? std::make_optional(position.altitude_accuracy)
           : std::nullopt,
